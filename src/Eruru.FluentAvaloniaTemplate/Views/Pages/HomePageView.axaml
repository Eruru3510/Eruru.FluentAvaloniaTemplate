<UserControl
	x:Class="Eruru.FluentAvaloniaTemplate.HomePageView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:res="using:Eruru.FluentAvaloniaTemplate.Resources"
	xmlns:vm="using:Eruru.FluentAvaloniaTemplate.ViewModels"
	d:DesignHeight="450"
	d:DesignWidth="800"
	x:DataType="vm:HomePageViewModel"
	mc:Ignorable="d">
	<StackPanel Margin="8">
		<TextBlock Text="{I18N Key={x:Static res:LangKeys.HomePage}}" />
		<TextBlock Text="{Binding Text}" />
	</StackPanel>
</UserControl>